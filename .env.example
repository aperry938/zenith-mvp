# ZENith Configuration
# Copy this file to .env and fill in your values

# Server
ZENITH_HOST=0.0.0.0
ZENITH_PORT=8000
ZENITH_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Models
ZENITH_MODEL_DIR=.

# Gemini Vision API (optional — falls back to mock coaching without this)
GEMINI_API_KEY=

# Logging (DEBUG, INFO, WARNING, ERROR)
ZENITH_LOG_LEVEL=INFO
